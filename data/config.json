{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "api_key_env": "NANOGPT_API_KEY",
    "base_url": "https://nano-gpt.com/api/v1"
  },
  "sources": {
    "rss": [
      { "name": "The Verge", "url": "https://www.theverge.com/rss/gadgets/index.xml" },
      { "name": "9to5Google", "url": "https://9to5google.com/feed/" },
      { "name": "TechCrunch", "url": "https://techcrunch.com/feed/" }
    ],
    "hackernews": { "enabled": true, "fetch_top_stories": 15, "min_score": 100 }
  },
  "filtering": {
    "ai_score_threshold": 3.0,
    "time_window_hours": 24
  },
  "summary": {
    "language": "ru",
    "detail_level": "medium"
  }
}
