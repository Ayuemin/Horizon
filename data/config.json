{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "api_key_env": "NANOGPT_API_KEY",
    "base_url": "https://nano-gpt.com/api/v1",
    "languages": ["ru"]
  },
  "sources": {
    "rss": [
      { "name": "It's FOSS", "url": "https://itsfoss.com/feed/" },
      { "name": "9to5Linux", "url": "https://9to5linux.com/feed" },
      { "name": "Phoronix", "url": "https://www.phoronix.com/phoronix-rss.php" },
      { "name": "DebugPoint", "url": "https://www.debugpoint.com/feed/" },
      { "name": "OMG! Ubuntu!", "url": "https://www.omgubuntu.co.uk/feed" },
      { "name": "Linux Today", "url": "https://www.linuxtoday.com/feed/" }
    ],
    "reddit": { 
      "enabled": true,
      "subreddits": ["opensource", "selfhosted", "fossdroid"],
      "limit_per_sub": 10
    },
    "hackernews": { 
      "enabled": true, 
      "fetch_top_stories": 20, 
      "min_score": 200 
    },
    "telegram": { "enabled": false }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "summary": {
    "language": "ru",
    "detail_level": "high"
  }
}
